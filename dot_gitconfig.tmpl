[user]
	name = Terry Horner
	email = {{ .email }}
	signingkey = {{ .gpg_key }}
[commit]
	gpgsign = true
[gpg]
	program = gpg
[github]
	user = terrhorn
[push]
	default = simple
[credential]
	helper = osxkeychain
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[init]
	defaultBranch = main
