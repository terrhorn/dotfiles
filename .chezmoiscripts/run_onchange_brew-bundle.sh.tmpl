#!/bin/bash
set -euo pipefail

# chezmoi re-runs this script when any Brewfile changes (sha256sum triggers)
# shared: {{ include "dot_config/homebrew/Brewfile" | sha256sum }}
{{- if .is_work }}
# machine: {{ include "dot_config/homebrew/Brewfile.work" | sha256sum }}
{{- else }}
# machine: {{ include "dot_config/homebrew/Brewfile.personal" | sha256sum }}
{{- end }}

# Cache sudo credentials once; refresh in background so they don't expire
sudo -v
while true; do sudo -n true; sleep 30; kill -0 "$$" || exit; done 2>/dev/null &

SOURCE_DIR="{{ .chezmoi.sourceDir }}/dot_config/homebrew"

COMBINED="$(mktemp)"
trap 'rm -f "$COMBINED"' EXIT

cat "$SOURCE_DIR/Brewfile" > "$COMBINED"
{{- if .is_work }}
cat "$SOURCE_DIR/Brewfile.work" >> "$COMBINED"
{{- else }}
cat "$SOURCE_DIR/Brewfile.personal" >> "$COMBINED"
{{- end }}

brew bundle --file="$COMBINED"
