{{- /* promptBoolOnce returns the stored value if set (safe non-interactive re-init);
       otherwise prompts on a TTY, or accepts --promptBool "Is this a work machine=true"
       non-interactively. No silent default — a fresh init with neither errors loudly. */ -}}
{{- $isWork := promptBoolOnce . "is_work" "Is this a work machine" -}}

[data]
  is_work = {{ $isWork }}
{{- if $isWork }}
  email = {{ promptStringOnce . "email" "Work email address" | quote }}
  signing_key = "id_ed25519"
{{- else }}
  email = "terry.horner@protonmail.com"
  signing_key = "id_ed25519_signing"
{{- end }}
